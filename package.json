{
  "name": "botium-connector-genesys",
  "version": "0.0.10",
  "description": "Botium Connector for Genesys",
  "type": "module",
  "main": "dist/botium-connector-genesys-cjs.cjs",
  "module": "dist/botium-connector-genesys-es.js",
  "exports": {
    ".": {
      "import": "./dist/botium-connector-genesys-es.js",
      "require": "./dist/botium-connector-genesys-cjs.cjs",
      "default": "./dist/botium-connector-genesys-cjs.cjs"
    }
  },
  "scripts": {
    "build": "rollup -c && cp logo.png dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "eslint": "eslint index.js src/**/*.js",
    "eslint-fix": "eslint --fix index.js src/**/*.js",
    "test": "mocha test/unittest/**/*spec.js",
    "test-nightly": "mocha test/nightly/**/*spec.js"
  },
  "author": "Botium GmbH",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/codeforequity-at/botium-core/issues"
  },
  "homepage": "https://www.botium.ai",
  "devDependencies": {
    "chai": "^4.3.7",
    "delay": "^5.0.0",
    "dotenv": "^16.0.3",
    "eslint": "^8.50.0",
    "eslint-config-standard": "^14.1.0",
    "eslint-plugin-import": "^2.18.2",
    "eslint-plugin-mocha": "^10.1.0",
    "eslint-plugin-node": "^10.0.0",
    "eslint-plugin-promise": "^4.2.1",
    "eslint-plugin-standard": "^4.0.1",
    "mocha": "^10.2.0",
    "nock": "v14.0.0-beta.19",
    "rollup": "^1.21.2",
    "rollup-plugin-json": "^4.0.0"
  },
  "dependencies": {
    "better-queue": "^3.8.12",
    "debug": "^4.1.1",
    "lodash": "^4.17.15",
    "mime-types": "^2.1.35",
    "qs": "^6.11.0",
    "randomatic": "^3.1.1",
    "uuid": "^7.0.3",
    "ws": "^7.5.9"
  },
  "peerDependencies": {
    "botium-core": "^1.15.6"
  }
}
